{
  "name": "claude-baton",
  "version": "2.1.2",
  "description": "Session lifecycle management for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-baton": "bin/claude-baton.js"
  },
  "files": [
    "dist",
    "bin",
    "prompts",
    "commands",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "session",
    "checkpoint",
    "resume",
    "lifecycle"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepare": "tsc",
    "build": "tsc",
    "test": "vitest run",
    "dev": "node dist/index.js",
    "lint": "tsc --noEmit",
    "format:check": "npx prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "npx prettier --write 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "license": "MIT",
  "author": "bakabaka91",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bakabaka91/claude-baton.git"
  },
  "homepage": "https://github.com/bakabaka91/claude-baton#readme",
  "bugs": {
    "url": "https://github.com/bakabaka91/claude-baton/issues"
  }
}
